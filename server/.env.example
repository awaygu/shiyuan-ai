# ── LLM Configuration ──────────────────────────────────────────
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Crawler Intervals (seconds) ────────────────────────────────
CRAWL_INTERVAL=1800
NEWSNOW_CRAWL_INTERVAL=1800
RSS_CRAWL_INTERVAL=1800

# ── Schedule ──────────────────────────────────────────────────
SCHEDULE_ENABLED=true

# ── NewsNow API ────────────────────────────────────────────────
# Local Docker (recommended for development): http://localhost:4444/api/s
# Public instance (fallback): https://newsnow.busiyi.world/api/s
NEWSNOW_API_URL=http://localhost:4444/api/s

# ── Keywords ──────────────────────────────────────────────────
KEYWORDS_FILE=keywords.txt
# Enable keyword filtering (default: true)
KEYWORDS_FILTER_ENABLED=true

# ── Publishing ────────────────────────────────────────────────
PUBLISH_RETRY=3

# ── WeChat Official Account (certified service account) ──────
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# ── Browser Automation (Playwright) ───────────────────────────
# 默认 true（headless）。本地扫码登录时可临时改 false 看浏览器窗口；
# Docker 部署由 docker-compose.yml 强制覆盖为 true，此处设置不生效。
PUBLISH_HEADLESS=true
PUBLISH_TIMEOUT=120

# ── Jina Reader (free, no API key required) ───────────────────
JINA_READER_URL=https://r.jina.ai

# ── DashScope (Alibaba Cloud) ─────────────────────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ── AI Image Generation ─────────────────────────────────────
IMAGE_GEN_ENABLED=true
IMAGE_GEN_MODEL=qwen-image-2.0-pro

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated origins, or * for all (development only)
CORS_ORIGINS=*

# ── Knowledge Base ─────────────────────────────────────────────
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_EMBEDDING_DIM=1024
KB_EMBEDDING_MODEL=text-embedding-v4
KB_VISION_MODEL=qwen-vl-ocr-latest
KB_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Max upload file size in bytes (default: 20MB)
MAX_UPLOAD_SIZE=20971520

# ── Memory (Short-term) ────────────────────────────────────────
MEMORY_DB_PATH=data/agent_memory.db
# Model used for conversation summarization
SUMMARY_MODEL=deepseek-v4-flash
# Override base URL and API key for summary model (defaults to LLM_BASE_URL / LLM_API_KEY)
# SUMMARY_MODEL_BASE_URL=https://api.openai.com/v1
# SUMMARY_MODEL_API_KEY=sk-your-key-here
SUMMARY_TRIGGER_TOKENS=80000
SUMMARY_KEEP_MESSAGES=10

# ── KB RAG Memory ───────────────────────────────────────────────
KB_RAG_SUMMARY_TRIGGER_TOKENS=50000
KB_RAG_SUMMARY_KEEP_MESSAGES=8
KB_RAG_MEMORY_DB_PATH=data/rag_memory.db

# ── Web Search ─────────────────────────────────────────────────
WEB_SEARCH_ENABLED=true
# 搜索引擎：kimi / tavily（默认 tavily）
WEB_SEARCH_ENGINE=tavily

# Tavily Search（WEB_SEARCH_ENGINE=tavily 时需要）
# 注册并获取 key：https://tavily.com（免费额度 1000 次/月）
TAVILY_API_KEY=tvly-your-tavily-key-here

# Kimi $web_search（WEB_SEARCH_ENGINE=kimi 时需要）
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# ── Temperature Strategy (optional, all have defaults) ───────────
# Lower for structured/deterministic tasks, higher for creative tasks
# TEMPERATURE_REWRITE=0.0      # query rewrite (JSON output)
# TEMPERATURE_SUMMARY=0.3      # conversation summarization
# TEMPERATURE_ANALYZE=0.7      # news interpretation/analysis
# TEMPERATURE_GENERATE=0.8     # article generation
# TEMPERATURE_CHAT=0.7         # chat/dialogue

# ── Prompt Guardrails (optional, all have defaults) ──────────────
# MAX_RAG_CONTEXT_CHARS=15000   # max chars for retrieved KB context
